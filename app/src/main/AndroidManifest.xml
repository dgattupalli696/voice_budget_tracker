<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Voice Recognition Permission -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".BudgetTrackerApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:hardwareAccelerated="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VoiceBudgetTracker"
        tools:targetApi="31">
        
        <!-- LiteRT-LM GPU support -->
        <uses-native-library android:name="libvndksupport.so" android:required="false"/>
        <uses-native-library android:name="libOpenCL.so" android:required="false"/>
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.VoiceBudgetTracker">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            
            <!-- App Shortcuts -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>
        
        <!-- Activity for Add Expense Shortcut -->
        <activity-alias
            android:name=".AddExpenseShortcut"
            android:targetActivity=".MainActivity"
            android:exported="false">
        </activity-alias>
        
        <!-- Activity for Voice Input Shortcut -->
        <activity-alias
            android:name=".VoiceInputShortcut"
            android:targetActivity=".MainActivity"
            android:exported="false">
        </activity-alias>
        
        <!-- Home Screen Widget -->
        <receiver
            android:name=".widget.AddExpenseWidget"
            android:exported="true"
            android:label="@string/widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_add_expense_info" />
        </receiver>
    </application>

</manifest>
